# Ansible real inventory (use inventory.example.ini as template)
ansible/inventory.ini

# Environment & Secrets - NEVER COMMIT
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
*secret*
*password*
*credentials*
unseal-keys*
root-token*

# Terraform
*.tfstate
*.tfstate.*
*.tfstate.backup
**/.terraform/
.terraform.lock.hcl
terraform.tfvars
!terraform.tfvars.example
plan.out
*.plan

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# Node
node_modules/
.next/
dist/
build/
*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Docker
.docker/

# Vault
vault-data/
vault-logs/
